{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.13.7/.schema/devbox.schema.json",
  "packages": [
    "git@latest",
    "gh@latest",
    "nodejs@22",
    "pnpm@latest",
    "python@3.12",
    "uv@latest"
  ],
  "shell": {
    "init_hook": [
      "export UV_PROJECT_ENVIRONMENT=\"$PWD/training/.venv\"",
      "echo '🚀 Devbox shell に入りました'",
      "echo '📖 よく使うコマンド, サーバー起動手順は docs/commands.md を参照'"
    ],
    "scripts": {
      "setup": [
        "pnpm install",
        "cd training && uv sync"
      ],
      "dev": [
        "pnpm dev"
      ],
      "build": [
        "pnpm build"
      ],
      "test": [
        "echo '【TODO】テスト未導入。導入時に pnpm test --coverage 等を記載'"
      ],
      "lint": [
        "pnpm lint"
      ],
      "lint:fix": [
        "pnpm lint:fix"
      ],
      "format": [
        "pnpm format"
      ],
      "format:check": [
        "pnpm format:check"
      ],
      "typecheck": [
        "pnpm typecheck"
      ]
    }
  },
  "env": {
    "PROJECT_ROOT": "$PWD"
  }
}
