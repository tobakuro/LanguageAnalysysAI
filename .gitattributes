# デフォルト: テキストファイルはLFで正規化
* text=auto eol=lf

# 明示的にテキストとして扱うファイル
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.env text eol=lf
*.example text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.editorconfig text eol=lf

# バイナリファイルは変換しない
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
